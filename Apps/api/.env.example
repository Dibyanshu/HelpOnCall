APP_ENV=development
DB_PROVIDER=turso
PORT=3000
HOST=0.0.0.0
JWT_SECRET=change-this-to-a-long-random-secret
SQLITE_DB_PATH=./db/database.sqlite

# Current runtime contract:
# - staging and production require Turso variables
# - production Cloudways managed DB migration is tracked separately
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# CloudWays managed MySQL — required only when APP_ENV=production
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# Future Cloudways managed DB placeholders (not active in runtime code yet)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=false

SUPER_ADMIN_EMAIL=superadmin@helponcall.local
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Mail Service (Gmail SMTP compatible)
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_REPLY_TO=
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
# Comma-separated origins for stricter production CORS, e.g. https://<web-cloudways-url>
CORS_ALLOWED_ORIGINS=

# Employment Resume Upload
EMPLOYMENT_RESUME_UPLOAD_DIR=./uploads/resumes
EMPLOYMENT_RESUME_MAX_FILE_SIZE_MB=10
