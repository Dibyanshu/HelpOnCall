{
  "version": 2,
  "builds": [
    {
      "src": "api/src/vercel.ts",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "web/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/src/vercel.ts"
    },
    {
      "src": "/web",
      "dest": "/web/index.html"
    },
    {
      "src": "/web/(.*)",
      "dest": "/web/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/index.html",
      "dest": "/web/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/web/index.html"
    }
  ]
}
